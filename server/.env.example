NODE_ENV=development
PORT=5000

# Postgres (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# Stripe (test mode). Subscription Price IDs are created by scripts/stripe-setup.ts
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ESSENTIAL=price_xxx
STRIPE_PRICE_UNLIMITED=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=hello@pulsestudio.app
STUDIO_EMAIL=hello@pulsestudio.app

# Cloudinary (class / instructor images)
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# CORS + redirects
CLIENT_URL=http://localhost:5173

# Seed admin
ADMIN_EMAIL=admin@pulsestudio.app
ADMIN_PASSWORD=Pulse2024!
