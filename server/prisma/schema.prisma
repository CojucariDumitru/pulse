// PULSE — boutique fitness studio
// "Find your rhythm."

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Auth ─────────────────────────

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Member {
  id               String      @id @default(cuid())
  email            String      @unique
  password         String
  name             String
  phone            String?
  stripeCustomerId String?     @unique
  membership       Membership?
  bookings         Booking[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

// ─────────────────────── Memberships ───────────────────────

enum MembershipPlan {
  ESSENTIAL
  UNLIMITED
  ANNUAL
}

enum MembershipStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INACTIVE
}

model Membership {
  id                   String           @id @default(cuid())
  member               Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId             String           @unique
  plan                 MembershipPlan
  status               MembershipStatus @default(INACTIVE)
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([status])
}

// ─────────────────────── Classes ───────────────────────

enum Intensity {
  LOW
  MEDIUM
  HIGH
  ALL_LEVELS
}

model ClassType {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String
  intensity   Intensity      @default(ALL_LEVELS)
  durationMin Int            @default(45)
  color       String         @default("#CCFF00") // accent used in UI
  image       String?
  order       Int            @default(0)
  sessions    ClassSession[]
  createdAt   DateTime       @default(now())
}

model Instructor {
  id          String         @id @default(cuid())
  name        String
  bio         String
  image       String?
  specialties String[]
  order       Int            @default(0)
  sessions    ClassSession[]
  createdAt   DateTime       @default(now())
}

model ClassSession {
  id           String     @id @default(cuid())
  classType    ClassType  @relation(fields: [classTypeId], references: [id], onDelete: Cascade)
  classTypeId  String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  instructorId String
  startsAt     DateTime
  durationMin  Int        @default(45)
  capacity     Int        @default(16)
  room         String?
  bookings     Booking[]
  createdAt    DateTime   @default(now())

  @@index([startsAt])
  @@index([classTypeId])
}

// ─────────────────────── Bookings ───────────────────────

enum BookingStatus {
  BOOKED
  WAITLIST
  CANCELLED
  ATTENDED
}

model Booking {
  id        String        @id @default(cuid())
  member    Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  session   ClassSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  status    BookingStatus @default(BOOKED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([memberId, sessionId])
  @@index([sessionId])
  @@index([memberId])
}

// ─────────────────────── Misc ───────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}
